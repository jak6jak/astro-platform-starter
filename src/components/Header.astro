---
const navItems = [
    { linkText: 'How it works', href: '/#how-it-works' },
    { linkText: 'Methods', href: '/#methods' }
];
---

<nav class="flex flex-wrap items-center justify-between gap-4 pt-6 pb-16 sm:pt-12 sm:pb-24">
    <a href="/" class="flex items-center gap-2 no-underline hover:opacity-90">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" class="text-primary">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span class="text-xl font-bold tracking-tight">Concord</span>
    </a>
    <div class="flex items-center gap-2">
        {
            navItems.map((item) => (
                <a href={item.href} class="px-3 py-2 text-sm text-white/75 no-underline hover:text-white hover:opacity-100 transition-colors">
                    {item.linkText}
                </a>
            ))
        }
        <a href="/decisions/new" class="btn ml-2">Start a Decision</a>
    </div>
</nav>
