---
export const prerender = false;
import { getStore } from '@netlify/blobs';
import Layout from '../../../layouts/Layout.astro';
import type { Decision, Vote, VoteTally } from '../../../types';

const { id } = Astro.params;

const decisionStore = getStore({ name: 'decisions', consistency: 'strong' });
const decision: Decision | null = await decisionStore.get(id!, { type: 'json' });

if (!decision) {
    return new Response(null, { status: 404 });
}

const counts = new Array<number>(decision.options.length).fill(0);
const voteStore = getStore({ name: `votes-${id}`, consistency: 'strong' });
const { blobs } = await voteStore.list();

for (const blob of blobs) {
    const vote: Vote | null = await voteStore.get(blob.key, { type: 'json' });
    if (vote && vote.optionIndex >= 0 && vote.optionIndex < counts.length) {
        counts[vote.optionIndex]++;
    }
}

const totalVotes = counts.reduce((sum, c) => sum + c, 0);
const tallies: VoteTally[] = decision.options.map((option, i) => ({ option, count: counts[i] }));
const winner = totalVotes > 0 ? tallies.reduce((best, t) => (t.count > best.count ? t : best), tallies[0]) : null;
const voteUrl = new URL(`/decisions/${id}/vote`, Astro.request.url).href;
---

<Layout title={`Results — ${decision.question} — Concord`}>
    <div class="py-12">
        <div class="mx-auto max-w-xl">

            <!-- Share link — prominent at the top so creators can immediately share -->
            <div class="mb-8 rounded-2xl border border-white/15 bg-white/8 p-5">
                <p class="mb-1 text-sm font-semibold text-white">Share this poll</p>
                <p class="mb-3 text-xs text-white/50">Send this link to participants — no account needed to vote.</p>
                <div class="flex items-center gap-2 rounded-lg border border-white/15 bg-black/20 px-3 py-2">
                    <span id="vote-url" class="flex-1 truncate text-sm text-white/70">{voteUrl}</span>
                    <button
                        id="copy-btn"
                        type="button"
                        class="shrink-0 rounded-md bg-[--color-primary] px-3 py-1.5 text-xs font-semibold text-white hover:opacity-90 transition-opacity"
                        data-url={voteUrl}
                    >
                        Copy link
                    </button>
                </div>
            </div>

            <!-- Question + vote count -->
            <p class="mb-1 text-sm font-medium uppercase tracking-widest text-white/40">Results</p>
            <h1 class="mb-2 text-3xl font-bold">{decision.question}</h1>
            <p class="mb-8 text-white/50 text-sm">{totalVotes} {totalVotes === 1 ? 'vote' : 'votes'} · updates when you refresh</p>

            <!-- Tallies -->
            {totalVotes === 0 ? (
                <div class="mb-8 rounded-2xl border border-white/10 bg-white/5 px-6 py-10 text-center">
                    <p class="text-white/50">No votes yet. Share the link above to get started.</p>
                </div>
            ) : (
                <div class="mb-8 flex flex-col gap-3">
                    {tallies.map((tally) => {
                        const pct = totalVotes > 0 ? Math.round((tally.count / totalVotes) * 100) : 0;
                        const isWinner = winner?.option === tally.option;
                        return (
                            <div class={`rounded-xl p-5 ${isWinner ? 'bg-[--color-primary]' : 'bg-white'}`}>
                                <div class="mb-2.5 flex items-center justify-between gap-2">
                                    <span class={`font-semibold ${isWinner ? 'text-white' : 'text-gray-800'}`}>
                                        {tally.option}
                                    </span>
                                    <div class="flex items-center gap-2 shrink-0">
                                        {isWinner && (
                                            <span class="rounded-full bg-white/25 px-2 py-0.5 text-xs font-bold uppercase tracking-wide text-white">
                                                Winner
                                            </span>
                                        )}
                                        <span class={`text-sm tabular-nums ${isWinner ? 'text-white/75' : 'text-gray-400'}`}>
                                            {tally.count} {tally.count === 1 ? 'vote' : 'votes'} · {pct}%
                                        </span>
                                    </div>
                                </div>
                                <div class={`h-2 w-full overflow-hidden rounded-full ${isWinner ? 'bg-white/25' : 'bg-gray-100'}`}>
                                    <div
                                        class={`h-full rounded-full ${isWinner ? 'bg-white' : 'bg-[--color-primary]'}`}
                                        style={`width: ${pct}%`}
                                    ></div>
                                </div>
                            </div>
                        );
                    })}
                </div>
            )}

            <!-- Actions -->
            <div class="flex items-center gap-3">
                <a href={`/decisions/${id}/vote`} class="btn">Cast your vote</a>
                <a href="/decisions/new" class="text-sm text-white/50 hover:text-white transition-colors no-underline">
                    Start a new decision →
                </a>
            </div>
        </div>
    </div>
</Layout>

<script>
    const btn = document.getElementById('copy-btn') as HTMLButtonElement;
    btn?.addEventListener('click', async () => {
        const url = btn.dataset.url ?? '';
        await navigator.clipboard.writeText(url);
        const original = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = original; }, 2000);
    });
</script>
